{
  "_comment": "Databricks job config for bronze-to-silver transformation.",
  "_usage": "Create this job via: databricks jobs create --json @bronze_to_silver_job.json",
  "_airflow": "Reference the returned job_id in Airflow variable: databricks_job_bronze_silver",

  "name": "project2-bronze-to-silver",
  "description": "Transforms raw bronze data to cleaned silver layer for all domains",

  "tasks": [
    {
      "task_key": "orders_bronze_to_silver",
      "description": "Clean and validate raw order events",
      "notebook_task": {
        "notebook_path": "/Repos/project2/databricks/notebooks/orders_bronze_to_silver",
        "base_parameters": {
          "s3_bucket": "project2-data-lake-dev",
          "dry_run": "false"
        },
        "source": "WORKSPACE"
      },
      "existing_cluster_id": "{{CLUSTER_ID}}",
      "timeout_seconds": 3600,
      "max_retries": 2,
      "min_retry_interval_millis": 300000
    },
    {
      "task_key": "transactions_bronze_to_silver",
      "description": "Clean, validate, and flag financial transactions",
      "notebook_task": {
        "notebook_path": "/Repos/project2/databricks/notebooks/transactions_bronze_to_silver",
        "base_parameters": {
          "s3_bucket": "project2-data-lake-dev",
          "lookback_days": "7"
        },
        "source": "WORKSPACE"
      },
      "existing_cluster_id": "{{CLUSTER_ID}}",
      "timeout_seconds": 3600,
      "max_retries": 2,
      "min_retry_interval_millis": 300000
    },
    {
      "task_key": "customers_bronze_to_silver",
      "description": "Normalise customer PII and build entity resolution blocking keys",
      "notebook_task": {
        "notebook_path": "/Repos/project2/databricks/notebooks/customers_bronze_to_silver",
        "base_parameters": {
          "s3_bucket": "project2-data-lake-dev"
        },
        "source": "WORKSPACE"
      },
      "existing_cluster_id": "{{CLUSTER_ID}}",
      "timeout_seconds": 1800,
      "max_retries": 2,
      "min_retry_interval_millis": 300000
    }
  ],

  "job_clusters": [],

  "schedule": {
    "_comment": "Airflow owns the schedule — do not set a Databricks schedule",
    "quartz_cron_expression": null
  },

  "tags": {
    "project": "project2",
    "layer": "silver",
    "team": "data-engineering"
  },

  "max_concurrent_runs": 1
}
